# Application
APP_NAME="MVCCore API"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

# API Security
API_KEY=your-secret-api-key-here
JWT_SECRET=your-jwt-secret-key

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mvccore_api
DB_USERNAME=root
DB_PASSWORD=

# CORS
ALLOWED_ORIGINS=*
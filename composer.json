    "keywords": [
        "mvc",
        "framework",
        "php",
        "router",
        "nextjs",
        "file-based-routing",
        "flow",
        "lightweight",
        "api"
    ],
    "homepage": "https://github.com/lizzyman04/fluxor",
    "license": "MIT",
    "authors": [
        {
            "name": "Arlindo",
            "email": "admin@tudocomlizzyman.com",
            "homepage": "https://lizzyman04.omeu.space",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {

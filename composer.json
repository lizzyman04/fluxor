{
    "name": "lizzyman04/fluxor",
    "description": "A lightweight PHP MVC engine with file-based routing and elegant Flow syntax.",
    "type": "library",
    "keywords": [
        "mvc",
        "framework",
        "php",
        "router",
        "nextjs",
        "file-based-routing",
        "flow",
        "lightweight",
        "api",
        "micro-framework"
    ],
    "homepage": "https://github.com/lizzyman04/fluxor",
    "license": "MIT",
    "authors": [
        {
            "name": "Arlindo",
            "email": "admin@tudocomlizzyman.com",
            "homepage": "https://lizzyman04.omeu.space",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Fluxor\\": "src/"
        },
        "files": [
            "src/Fluxor.php",
            "src/Helpers/Functions.php"
        ]
    },
    "scripts": {
        "clear-router-cache": "php -r \"require 'vendor/autoload.php'; \\Fluxor\\Core\\Http\\Router\\Matcher::clearRouterCache();\""
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "version": "1.0.3"
}
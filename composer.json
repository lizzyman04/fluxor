{
    "name": "lizzyman04/mvccore",
    "description": "A lightweight PHP MVC core with Next.js-style file-based routing, elegant Flow syntax, and powerful features",
    "type": "library",
    "keywords": [
        "mvc",
        "framework",
        "php",
        "router",
        "nextjs",
        "filesystem",
        "api",
        "elegant",
        "lightweight"
    ],
    "homepage": "https://github.com/lizzyman04/mvccore",
    "license": "MIT",
    "authors": [
        {
            "name": "Arlindo Augusto",
            "email": "admin@tudocomlizzyman.com",
            "homepage": "https://github.com/lizzyman04",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "symfony/var-dumper": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "MVCCore\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MVCCore\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "MVCCore\\Installer::postInstall"
        ],
        "post-update-cmd": [
            "MVCCore\\Installer::postUpdate"
        ],
        "mvccore-install": [
            "MVCCore\\Installer::install"
        ],
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}